{
  "name": "strideo-web",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx --test lib/ml/data-contract/readiness-check.test.ts lib/racing-codes/normalization-core.test.ts lib/provider-ingestion/racing-form-parser-core.test.ts lib/provider-ingestion/provider-race-entry-adapter-core.test.ts",
    "db:migrations:check": "node scripts/check-supabase-migrations.mjs",
    "db:migrations:list": "node scripts/supabase-cli-with-env.mjs migration list --linked",
    "db:migrations:dry-run": "node scripts/supabase-cli-with-env.mjs db push --linked --dry-run",
    "db:lint": "node scripts/supabase-cli-with-env.mjs db lint --linked",
    "opportunities:generate:demo": "NODE_OPTIONS=--conditions=react-server tsx scripts/generate-demo-opportunities.ts",
    "racing-codes:unresolved:report": "NODE_OPTIONS=--conditions=react-server tsx scripts/report-unresolved-racing-codes.ts",
    "verify": "npm run db:migrations:check && npm run lint && npm run test && npm run build && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
